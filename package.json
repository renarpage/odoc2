{
  "name": "odoc-digital-archive",
  "version": "2.0.0",
  "description": "ODOC Digital Archive - production backend (Express + MongoDB + JWT + Google Drive) integrated with the existing EJS/Bootstrap/GSAP frontend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seeders/seed.js",
    "sync": "browser-sync start --proxy localhost:3000 --files views/**/*.ejs, public/**/*.css"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "googleapis": "^140.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "nodemon": "^3.1.0"
  }
}
