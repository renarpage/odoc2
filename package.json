{
  "name": "odoc-digital-archive",
  "version": "1.0.0",
  "description": "ODOC Digital Archive - Guest & Admin panel (Express + EJS + Bootstrap + GSAP)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon -e * server.js",
    "sync": "browser-sync start --proxy localhost:3000 --files views/**/*.ejs, public/**/*.css"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "browser-sync": "^3.0.4",
    "connect-flash": "^0.1.1",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
