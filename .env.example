# ---- Application ----
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ---- MongoDB ----
MONGO_URI=mongodb://127.0.0.1:27017/odoc

# ---- JWT / Auth ----
# Generate strong secrets, e.g. `openssl rand -hex 48`
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_TTL_DAYS=7
BCRYPT_ROUNDS=12

# ---- Cookies ----
COOKIE_SECURE=false
# COOKIE_DOMAIN=.yourdomain.com

# ---- Google Drive via OAuth (RECOMMENDED) ----
# 1. Google Cloud Console > APIs & Services > Credentials > Create OAuth client ID (Web application)
# 2. Add this Authorized redirect URI:
#      http://localhost:3000/admin/integrations/google/callback
# 3. Enable the Google Drive API for the project.
# 4. Paste the client id/secret below, start the app, then go to
#      Admin > Storage > "Connect Google Drive" and sign in with YOUR account.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override; defaults to APP_URL + /admin/integrations/google/callback
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/admin/integrations/google/callback

# ---- Google Drive via service account (FALLBACK / headless) ----
GOOGLE_DRIVE_ENABLED=false
GOOGLE_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Displayed capacity in GB, used when Drive reports no fixed quota limit.
# With OAuth to a personal account the real quota is used automatically.
STORAGE_CAPACITY_GB=15

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# ---- Uploads ----
MAX_UPLOAD_BYTES=52428800

# ---- Seed admin accounts (change immediately after first login) ----
SEED_SUPERADMIN_EMAIL=superadmin@odoc.archive
SEED_SUPERADMIN_PASSWORD=ChangeMe!Super123
SEED_ADMIN_EMAIL=admin@odoc.archive
SEED_ADMIN_PASSWORD=ChangeMe!Admin123
