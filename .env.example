NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/odoc

# JWT / Cookies
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
COOKIE_SECRET=change_me_cookie

# Google Drive (Service Account) - share the target folder with this email
GDRIVE_CLIENT_EMAIL=svc@project.iam.gserviceaccount.com
GDRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GDRIVE_ROOT_FOLDER_ID=your_root_folder_id
GDRIVE_QUOTA_BYTES=16106127360

# Uploads
MAX_IMAGE_MB=10
MAX_VIDEO_MB=200
MAX_DOC_MB=25

# Seed SuperAdmin
SEED_ADMIN_EMAIL=superadmin@smavo.sch.id
SEED_ADMIN_PASSWORD=SuperSecure#123
SEED_ADMIN_NAME=Super Admin OSIS
