# ---- Application ----
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ---- MongoDB ----
MONGO_URI=mongodb://127.0.0.1:27017/odoc

# ---- JWT / Auth ----
# Generate strong secrets, e.g. `openssl rand -hex 48`
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_TTL_DAYS=7
BCRYPT_ROUNDS=12

# ---- Cookies ----
# Set COOKIE_SECURE=true behind HTTPS in production
COOKIE_SECURE=false
# COOKIE_DOMAIN=.yourdomain.com

# ---- Google Drive (service account) ----
GOOGLE_DRIVE_ENABLED=false
GOOGLE_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
# Paste the private key with literal \n newlines, wrapped in quotes
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Displayed storage capacity in GB. Used when Drive reports no fixed quota
# limit (common with service accounts). Set to your real Drive size,
# e.g. 15 (free), 100, 200, 2048 (2TB). Real quota is preferred when present.
STORAGE_CAPACITY_GB=15

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# ---- Uploads ----
MAX_UPLOAD_BYTES=52428800

# ---- Seed admin accounts (change immediately after first login) ----
SEED_SUPERADMIN_EMAIL=superadmin@odoc.archive
SEED_SUPERADMIN_PASSWORD=ChangeMe!Super123
SEED_ADMIN_EMAIL=admin@odoc.archive
SEED_ADMIN_PASSWORD=ChangeMe!Admin123
