<div class="card auth-card">
  <div class="text-center mb-4">
    <div class="auth-brand">
      <span class="brand-mark">O</span>
      <span class="odoc-brand">ODOC</span>
    </div>
    <p class="text-muted mb-0" style="font-size:.9rem;">Enter the code &amp; new password</p>
  </div>

  <% if (typeof error !== 'undefined' && error.length) { %>
    <div class="alert alert-danger py-2" role="alert" style="border-radius:var(--radius-sm);"><%= error[0] %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success.length) { %>
    <div class="alert alert-success py-2" role="alert" style="border-radius:var(--radius-sm);"><%= success[0] %></div>
  <% } %>

  <div class="alert py-2 d-flex align-items-center gap-2" style="background:#E9EEFC;border:none;border-radius:var(--radius-sm);color:var(--odoc-primary);font-size:.82rem;">
    <i class="bi bi-terminal"></i> Your 6-digit code was printed to the server console.
  </div>

  <form method="POST" action="/reset-password" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="mb-3">
      <label class="form-label fw-semibold" for="email">Email</label>
      <input class="form-control" type="email" id="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>" placeholder="you@odoc.archive" required <%= (typeof email !== 'undefined' && email) ? 'readonly' : 'autofocus' %> />
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold" for="code">6-Digit Code</label>
      <input class="form-control text-center" style="letter-spacing:.5em;font-weight:700;font-size:1.15rem;" type="text" id="code" name="code" inputmode="numeric" pattern="\d{6}" maxlength="6" placeholder="000000" required <%= (typeof email !== 'undefined' && email) ? 'autofocus' : '' %> />
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold" for="newPassword">New Password</label>
      <input class="form-control" type="password" id="newPassword" name="newPassword" minlength="8" placeholder="At least 8 characters" required />
      <small class="text-muted">Minimum 8 characters, letters and numbers.</small>
    </div>

    <div class="mb-4">
      <label class="form-label fw-semibold" for="confirmPassword">Confirm New Password</label>
      <input class="form-control" type="password" id="confirmPassword" name="confirmPassword" minlength="8" placeholder="Re-enter new password" required />
    </div>

    <button class="btn btn-primary w-100 py-2" type="submit"><i class="bi bi-check2-circle me-2"></i>Reset Password</button>
  </form>

  <p class="text-center mt-4 mb-0">
    <a href="/forgot-password" class="small fw-semibold text-muted"><i class="bi bi-arrow-repeat me-1"></i>Request a new code</a>
  </p>
</div>
