<div class="card auth-card">
  <div class="text-center mb-4">
    <div class="auth-brand">
      <span class="brand-mark">O</span>
      <span class="odoc-brand">ODOC</span>
    </div>
    <p class="text-muted mb-0 auth-subtitle">Reset your password</p>
  </div>

  <% if (typeof error !== 'undefined' && error.length) { %>
    <div class="alert alert-danger py-2 alert-soft" role="alert"><%= error[0] %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success.length) { %>
    <div class="alert alert-success py-2 alert-soft" role="alert"><%= success[0] %></div>
  <% } %>

  <p class="text-muted auth-hint">Enter your account email and we'll generate a 6-digit verification code.</p>

  <form method="POST" action="/forgot-password" autocomplete="on">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="mb-4">
      <label class="form-label fw-semibold" for="email">Email</label>
      <input class="form-control" type="email" id="email" name="email" placeholder="you@odoc.archive" required autofocus />
    </div>
    <button class="btn btn-primary w-100 py-2" type="submit"><i class="bi bi-send me-2"></i>Send Code</button>
  </form>

  <p class="text-center mt-4 mb-0">
    <a href="/login" class="small fw-semibold text-muted"><i class="bi bi-arrow-left me-1"></i>Back to sign in</a>
  </p>
</div>
