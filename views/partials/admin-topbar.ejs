<header class="admin-topbar">
  <button class="sidebar-burger d-lg-none" id="sidebarBurger"><i class="bi bi-list"></i></button>
  <div class="gap-2 d-flex text-center justify-content-center align-items-center search-pill admin-search">
    <i class="bi bi-search"></i>
    <input type="search" class="form-control border-0 bg-transparent shadow-none" placeholder="Search activities, categories...">
  </div>

  <div class="topbar-right">
    <a href="/admin/activities/new" class="btn btn-primary rounded-pill px-3 d-none d-md-inline-flex">
      <i class="bi bi-plus-circle me-1"></i> Create New Activity
    </a>
    <div class="dropdown">
      <button class="icon-btn btn-secondary position-relative" id="notifBell" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" title="Notifications">
        <i class="bi bi-bell"></i>
        <span class="notif-dot" id="notifDot"></span>
      </button>
      <div class="dropdown-menu dropdown-menu-end notif-menu" aria-labelledby="notifBell">
        <div class="notif-head d-flex justify-content-between align-items-center">
          <span class="fw-bold small">Notifications</span>
          <a href="/admin" class="tiny text-primary text-decoration-none">View dashboard</a>
        </div>
        <div class="notif-list" id="notifList">
          <div class="notif-empty tiny">Loading…</div>
        </div>
      </div>
    </div>
    <a href="/logout" class="icon-btn btn-secondary d-none d-md-inline-flex" title="Logout">
      <i class="bi bi-box-arrow-right"></i>
    </a>
    <div class="topbar-user">
      <div class="text-end d-none d-sm-block">
        <div class="fw-semibold small"><%= (typeof currentUser !== 'undefined' && currentUser) ? currentUser.name : 'Admin' %></div>
        <div class="text-muted tiny"><%= (typeof currentUser !== 'undefined' && currentUser && currentUser.roleLabel) ? currentUser.roleLabel : 'Administrator' %></div>
      </div>
      <span class="avatar-img d-inline-flex align-items-center justify-content-center"><%= ((typeof currentUser !== 'undefined' && currentUser && currentUser.name) ? currentUser.name : 'A').charAt(0).toUpperCase() %></span>
    </div>
  </div>
</header>
