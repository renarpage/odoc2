<div class="container py-4">
  <a href="/" class="back-link"><i class="bi bi-arrow-left me-2"></i>Back to Archive</a>

  <div class="detail-hero mt-3 mb-4 card">
    <div class="d-flex gap-2 mb-3">
      <span class="status-chip ongoing" style="background:#fff;">
        <%= activity.category.toUpperCase() %>
      </span>
      <span class="status-chip <%= activity.status.toLowerCase() %>"><i class="bi bi-check-circle me-1"></i>
        <%= activity.status %>
      </span>
    </div>
    <h1 class="detail-title">
      <%= activity.title %>
    </h1>
    <div class="detail-meta">
      <i class="bi bi-calendar3 me-1"></i>
      <%= new Date(activity.date).toLocaleDateString('en-US', { month: 'long' , day: '2-digit' , year: 'numeric' }) %>
        &nbsp;|&nbsp;
        <i class="bi bi-geo-alt me-1"></i>
        <%= activity.location %>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="section-card mb-4 card">
        <div class="section-heading"><i class="me-2 bi bi-info-circle"></i>Event Overview</div>
        <div class="overview-text-box">
          <% activity.description.forEach(function(p) { %>
            <p class="mb-3">
              <%= p %>
            </p>
            <% }); %>
        </div>
      </div>

      <% if (activity.gallery.length) { %>
        <div class="section-card card mb-4">
          <div class="section-heading d-flex justify-content-between align-items-center text-centerpt-2">
            <div><i class="me-2 bi bi-images"></i>Media Archive</div>
            <div class="me-2 view-details-link">View Details <i class="ms-2 bi bi-arrow-right"></i></div>
          </div>
          <div class="gallery-grid">
            <% activity.gallery.forEach(function(img, i) { %>
              <div class="<%= (activity.gallery.length % 2 === 1 && i === 0) ? 'wide' : '' %>">
                <img src="<%= img %>" alt="Gallery image <%= i + 1 %>">
              </div>
              <% }); %>
          </div>
        </div>
        <% } %>

          <div class="section-card card">
            <div class="section-heading"><i class="me-2 bi bi-graph-up"></i>Milestones</div>
            <div class="milestone-list">
              <% activity.milestones.forEach(function(m) { %>
                <div class="milestone-item <%= m.current ? 'current' : '' %>">
                  <div class="milestone-title">
                    <%= m.title %>
                  </div>
                  <div class="milestone-date">
                    <%= m.date %>
                  </div>
                </div>
                <% }); %>
            </div>
          </div>
    </div>

    <div class="col-lg-4">
      
      <% if (activity.committee.length) { %>
        <div class="section-card card mb-4">
              <div class="section-heading"><i class="me-2 bi bi-people"></i>Core Committee</div>
              <% activity.committee.forEach(function(c, i) { %>
                <div class="committee-row">
                  <div class="d-flex align-items-center">
                    <img class="committee-avatar" src="https://i.pravatar.cc/80?img=<%= 20 + i %>" alt="<%= c.name %>">
                    <div>
                      <div class="fw-semibold small">
                        <%= c.name %>
                      </div>
                      <div class="text-muted tiny">
                        <%= c.role %>
                      </div>
                    </div>
                  </div>
                </div>
                <% }); %>
              </div>
              <% } %>
              
              <% if (activity.documents.length) { %>
                <div class="section-card card mb-4">
                  <div class="section-heading"><i class="me-2 bi bi-folder2"></i> Documents</div>
                  <% activity.documents.forEach(function(doc) { %>
                    <div class="doc-row">
                      <div class="d-flex align-items-center ">
                        <span class="doc-icon <%= doc.type %>"><i class="bi bi-file-earmark-text"></i></span>
                        <div>
                          <div class="fw-semibold small">
                            <%= doc.name %>
                          </div>
                          <div class="text-muted tiny">
                            <%= doc.size %>
                          </div>
                        </div>
                      </div>
                      <i class="bi bi-download text-muted"></i>
                    </div>
                    <% }); %>
                </div>
                <% } %>
                
              <a class="share-btn btn btn-primary w-100 rounded-pill py-3 fw-semibold share-btn">
                <i class="bi bi-share me-2"></i>Share Activity
              </a>
    </div>
  </div>
</div>