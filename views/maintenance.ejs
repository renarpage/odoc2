<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Maintenance - <%= platformName %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root {
      --primary: #3155E7;
      --bg: #f0f2f5;
    }
    body {
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }
    .maintenance-card {
      background: #fff;
      border-radius: 24px;
      box-shadow: 8px 8px 24px rgba(0,0,0,.08), -4px -4px 12px rgba(255,255,255,.9);
      padding: 3rem;
      text-align: center;
      max-width: 520px;
      width: 90%;
    }
    .maintenance-icon {
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, var(--primary), #6b7cff);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }
    .maintenance-icon i {
      font-size: 2rem;
      color: #fff;
    }
    h1 {
      font-size: 1.75rem;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: .75rem;
    }
    p {
      color: #6c757d;
      font-size: 1rem;
      line-height: 1.6;
      margin-bottom: 0;
    }
    .pulse {
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
  </style>
</head>
<body>
  <div class="maintenance-card">
    <div class="maintenance-icon pulse">
      <i class="bi bi-wrench-adjustable"></i>
    </div>
    <h1>Under Maintenance</h1>
    <p><%= maintenanceMessage %></p>
    <p class="mt-3" style="font-size:.875rem;color:#adb5bd;"><%= platformName %></p>
  </div>
</body>
</html>
