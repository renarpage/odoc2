<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' \u00b7 ODOC' : 'ODOC Digital Archive' %></title>
  <meta name="description" content="<%= (typeof meta !== 'undefined' && meta.description) || (typeof branding !== 'undefined' && branding.tagline) || 'Arsip digital kegiatan OSIS SMAVO' %>" />

  <!-- Bootstrap 5 + Icons (CDN) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

  <!-- Existing design system + new Neumorphism theme -->
  <link rel="stylesheet" href="/static/css/style.css" />
  <link rel="stylesheet" href="/assets/css/theme.css" />
  <%- include('../partials/theme-vars') %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <main id="butter">
    <%- body %>
    <%- include('../partials/footer') %>
  </main>

  <%- include('../partials/notification-toast') %>

  <!-- GSAP + ScrollTrigger + Lenis smooth scroll (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <!-- ODOC frontend behavior -->
  <script src="/assets/js/smooth-scroll.js"></script>
  <script src="/assets/js/lazyload.js"></script>
  <script src="/assets/js/toast.js"></script>
</body>
</html>
