<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
  <div>
    <h2 class="fw-bold mb-1">Activities</h2>
    <p class="text-muted mb-0">Manage every activity in the digital archive.</p>
  </div>
  <a href="/admin/activities/new" class="btn btn-primary rounded-pill px-4">
    <i class="bi bi-plus-circle me-2"></i>Create New Activity
  </a>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="stat-card card hover-none">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)"><i
          class="bi bi-bar-chart"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value">
          <%= stats.totalActivities.toLocaleString() %>
        </div>
        <div class="stat-label">Total Activities</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card card hover-none">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)"><i
          class="bi bi-cloud-arrow-up"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value">
          <%= stats.ongoingNow %>
        </div>
        <div class="stat-label">Ongoing Now</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card card hover-none">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)"><i
          class="bi bi-clock-history"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value">
          <%= stats.completedToday %>
        </div>
        <div class="stat-label">Completed Today</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card card hover-none">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)"><i
          class="bi bi-database"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value">
          <%= stats.dataArchivedTB %> TB
        </div>
        <div class="stat-label">Data Archived</div>
      </div>
    </div>
  </div>
</div>

<div class="odoc-panel">
  <div class="d-flex flex-wrap gap-2 mb-4">
    <select class="form-select form-select-odoc" style="max-width:180px;">
      <option>All Statuses</option>
      <option>Ongoing</option>
      <option>Completed</option>
      <option>Upcoming</option>
    </select>
    <select class="form-select form-select-odoc" style="max-width:200px;">
      <option>All Categories</option>
      <option>Festival</option>
      <option>Technology</option>
      <option>Organization</option>
      <option>Archival</option>
    </select>
    <input type="date" class="form-control form-control-odoc" style="max-width:200px;">
  </div>

  <div class="d-flex justify-content-between align-items-center mb-2">
    <span class="text-muted small">Showing 1–<%= activities.length %> of <%= activities.length %></span>
    <button class="btn btn-sm btn-light rounded-circle"><i class="bi bi-arrow-clockwise"></i></button>
  </div>

  <div class="table-responsive">
    <table class="table table-odoc mb-0">
      <thead>
        <tr>
          <th style="width:30px;"><input type="checkbox"></th>
          <th>Activity Name</th>
          <th>Category</th>
          <th>Date Created</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% activities.forEach(function(a) { %>
          <tr>
            <td><input type="checkbox"></td>
            <td>
              <div class="d-flex align-items-center gap-3">
                <img src="<%= a.cover %>" class="activity-thumb" alt="<%= a.title %>">
                <div>
                  <div class="fw-semibold">
                    <%= a.title %>
                  </div>
                  <div class="text-muted tiny">ID: <%= a.id.toUpperCase() %>
                  </div>
                </div>
              </div>
            </td>
            <td><span class="badge rounded-pill text-bg-light border">
                <%= a.category %>
              </span></td>
            <td>
              <%= new Date(a.createdAt).toLocaleDateString('en-US', { month: 'short' , day: '2-digit' , year: 'numeric'
                }) %>
            </td>
            <td>
              <span
                class="fw-semibold small
                <%= a.status === 'Completed' ? 'text-success' : (a.status === 'Ongoing' ? 'text-primary' : 'text-purple') %>">
                <i class="bi bi-circle-fill" style="font-size:.5rem;"></i>
                <%= a.status %>
              </span>
            </td>
            <td>
              <a href="/activity/<%= a.id %>" class="icon-btn me-1"
                style="width:34px;height:34px;display:inline-flex;"><i class="bi bi-eye"></i></a>
              <a href="/admin/activities/new" class="icon-btn" style="width:34px;height:34px;display:inline-flex;"><i
                  class="bi bi-pencil"></i></a>
            </td>
          </tr>
          <% }); %>
      </tbody>
    </table>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-4">
    <button class="btn btn-light rounded-pill px-3"><i class="bi bi-chevron-left me-1"></i>Previous</button>
    <div class="odoc-pagination">
      <a href="#" class="page-pill active">1</a>
      <a href="#" class="page-pill">2</a>
      <a href="#" class="page-pill">3</a>
      <span class="text-muted">...</span>
      <a href="#" class="page-pill">12</a>
    </div>
    <button class="btn btn-light rounded-pill px-3">Next<i class="bi bi-chevron-right ms-1"></i></button>
  </div>
</div>