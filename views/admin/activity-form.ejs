<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div class="d-flex align-items-center gap-2">
    <a href="/admin/activities" class="icon-btn"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h2 class="fw-bold mb-0">Activity Editor</h2>
      <div class="text-muted tiny"><i class="bi bi-circle-fill text-primary" style="font-size:.5rem;"></i> Autosaved a moment ago</div>
    </div>
  </div>
  <a href="/admin/activities" class="text-muted fw-semibold">Cancel</a>
</div>

<div class="odoc-panel" id="activityWizard">
  <div class="wizard-steps">
    <div class="wizard-step active" data-step="0">
      <div class="wizard-line"></div>
      <div class="circle">1</div>
      <div class="label">Basic Info</div>
    </div>
    <div class="wizard-step" data-step="1">
      <div class="wizard-line"></div>
      <div class="circle">2</div>
      <div class="label">Documentation</div>
    </div>
    <div class="wizard-step" data-step="2">
      <div class="wizard-line"></div>
      <div class="circle">3</div>
      <div class="label">Committee</div>
    </div>
    <div class="wizard-step" data-step="3">
      <div class="wizard-line"></div>
      <div class="circle">4</div>
      <div class="label">Review</div>
    </div>
  </div>

  <form action="/admin/activities/new" method="POST">
    <!-- STEP 1: BASIC INFO -->
    <div class="wizard-pane active">
      <h5 class="fw-bold mb-1">General Information</h5>
      <p class="text-muted small mb-4">Enter the fundamental details for your new digital archive activity.</p>

      <div class="mb-3">
        <label class="form-label-odoc">Activity Title</label>
        <input type="text" name="title" class="form-control form-control-odoc" placeholder="e.g. Annual Digital Preservation Summit 2024" required>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label-odoc">Category</label>
          <select name="category" class="form-select form-select-odoc">
            <option>Archive Gallery</option>
            <option>Festival</option>
            <option>Technology</option>
            <option>Organization</option>
            <option>Security Scan</option>
            <option>Sports</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label-odoc">Activity Date</label>
          <input type="date" name="date" class="form-control form-control-odoc">
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label-odoc">Location</label>
        <input type="text" name="location" class="form-control form-control-odoc" placeholder="e.g. Central Park Amphitheater">
      </div>

      <div class="mb-3">
        <label class="form-label-odoc">Description</label>
        <textarea name="description" rows="4" class="form-control form-control-odoc" placeholder="Provide a detailed overview of the activity purpose and scope..."></textarea>
      </div>
    </div>

    <!-- STEP 2: DOCUMENTATION -->
    <div class="wizard-pane">
      <h5 class="fw-bold mb-1">Resource Gallery & Documents</h5>
      <p class="text-muted small mb-4">Upload visual evidence and supporting documentation. Supported: JPG, PNG, PDF, DOCX.</p>

      <div class="upload-drop mb-3">
        <input type="file" hidden multiple>
        <i class="bi bi-cloud-arrow-up d-block mb-2"></i>
        <div class="fw-semibold text-dark">Drag &amp; drop files or <span class="text-primary">browse</span></div>
        <div class="tiny">Maximum file size: 50MB per file</div>
      </div>

      <div class="file-progress-row">
        <i class="bi bi-image text-primary"></i>
        <div class="flex-grow-1">
          <div class="small fw-semibold">summit_hero_photo.jpg</div>
          <div class="progress mt-1"><div class="progress-bar" style="width:75%"></div></div>
        </div>
        <span class="tiny">75%</span>
        <i class="bi bi-x text-muted"></i>
      </div>
      <div class="file-progress-row">
        <i class="bi bi-file-earmark-pdf text-danger"></i>
        <div class="flex-grow-1">
          <div class="small fw-semibold">activity_itinerary_v2.pdf</div>
          <div class="text-muted tiny">Upload complete</div>
        </div>
        <span class="tiny">2.4 MB</span>
        <i class="bi bi-trash text-muted"></i>
      </div>

      <div class="d-flex align-items-center gap-3 mt-4 p-3" style="background:var(--odoc-bg);border-radius:var(--radius-md);">
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=200" class="rounded-3" style="width:90px;height:70px;object-fit:cover;">
        <div class="flex-grow-1">
          <div class="fw-semibold text-primary small">Cover Image Preview</div>
          <div class="text-muted tiny">This image will represent the activity in the main Gallery and Timeline views.</div>
        </div>
        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill">Change Cover</button>
      </div>
    </div>

    <!-- STEP 3: COMMITTEE -->
    <div class="wizard-pane">
      <h5 class="fw-bold mb-1">Core Committee</h5>
      <p class="text-muted small mb-4">Assign the people responsible for this activity.</p>

      <div class="row g-3 align-items-end mb-3">
        <div class="col-md-5">
          <label class="form-label-odoc">Full Name</label>
          <input type="text" class="form-control form-control-odoc" placeholder="e.g. Sarah Jenkins">
        </div>
        <div class="col-md-5">
          <label class="form-label-odoc">Role</label>
          <input type="text" class="form-control form-control-odoc" placeholder="e.g. Project Director">
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-primary w-100 rounded-3"><i class="bi bi-plus-lg"></i></button>
        </div>
      </div>

      <div class="committee-row">
        <div class="d-flex align-items-center">
          <img class="committee-avatar" src="https://i.pravatar.cc/80?img=32">
          <div>
            <div class="fw-semibold small">Sarah Jenkins</div>
            <div class="text-muted tiny">Project Director</div>
          </div>
        </div>
        <i class="bi bi-x text-muted" style="cursor:pointer;"></i>
      </div>
    </div>

    <!-- STEP 4: REVIEW -->
    <div class="wizard-pane">
      <h5 class="fw-bold mb-1">Review & Publish</h5>
      <p class="text-muted small mb-4">Double check everything before it goes live on the public archive.</p>

      <div class="alert d-flex align-items-center gap-2" style="background:#E9EEFC;border:none;border-radius:var(--radius-md);color:var(--odoc-primary);">
        <i class="bi bi-info-circle"></i> All required fields are marked. Once published, this activity will appear immediately on the public Archive.
      </div>

      <div class="d-flex justify-content-end gap-2">
        <button type="submit" name="action" value="draft" class="btn btn-light rounded-pill px-4">Save Draft</button>
        <button type="submit" name="action" value="publish" class="btn btn-primary rounded-pill px-4">Publish Activity <i class="bi bi-send ms-1"></i></button>
      </div>
    </div>

    <div class="d-flex justify-content-between mt-4 pt-3 border-top">
      <button type="button" class="btn btn-light rounded-pill px-4" data-wizard-prev><i class="bi bi-chevron-left me-1"></i>Back</button>
      <button type="button" class="btn btn-primary rounded-pill px-4" data-wizard-next>Next<i class="bi bi-chevron-right ms-1"></i></button>
    </div>
  </form>
</div>
