<% var isEdit = (typeof mode !== 'undefined' && mode === 'edit' && activity); %>
<% function dval(d){ return d ? new Date(d).toISOString().slice(0,10) : ''; } %>
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div class="d-flex align-items-center gap-2">
    <a href="/admin/activities" class="icon-btn"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h2 class="fw-bold mb-0"><%= isEdit ? 'Edit Activity' : 'Create Activity' %></h2>
      <div class="text-muted tiny"><i class="bi bi-circle-fill text-primary" style="font-size:.5rem;"></i> <%= isEdit ? 'Editing ' + activity.title : 'New digital archive entry' %></div>
    </div>
  </div>
  <a href="/admin/activities" class="text-muted fw-semibold">Cancel</a>
</div>

<div class="odoc-panel" id="activityWizard">
  <div class="wizard-steps">
    <div class="wizard-step active" data-step="0"><div class="wizard-line"></div><div class="circle">1</div><div class="label">Basic Info</div></div>
    <div class="wizard-step" data-step="1"><div class="wizard-line"></div><div class="circle">2</div><div class="label">Documentation</div></div>
    <div class="wizard-step" data-step="2"><div class="wizard-line"></div><div class="circle">3</div><div class="label">Committee</div></div>
    <div class="wizard-step" data-step="3"><div class="wizard-line"></div><div class="circle">4</div><div class="label">Review</div></div>
  </div>

  <form action="<%= isEdit ? '/admin/activities/' + activity.id + '/edit' : '/admin/activities/new' %>?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- STEP 1: BASIC INFO -->
    <div class="wizard-pane active">
      <h5 class="fw-bold mb-1">General Information</h5>
      <p class="text-muted small mb-4">These fields drive the public activity page directly.</p>

      <div class="mb-3">
        <label class="form-label-odoc">Activity Title</label>
        <input type="text" name="title" class="form-control form-control-odoc" placeholder="e.g. SMAVO Music Festival 2024" value="<%= isEdit ? activity.title : '' %>" required>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label-odoc">Category</label>
          <select name="category" class="form-select form-select-odoc">
            <% ['Archive Gallery','Festival','Technology','Organization','Security Scan','Sports','Archival'].forEach(function(c){ %>
              <option <%= isEdit && activity.category === c ? 'selected' : '' %>><%= c %></option>
            <% }); %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label-odoc">Status</label>
          <select name="status" class="form-select form-select-odoc">
            <% ['Upcoming','Ongoing','Completed'].forEach(function(s){ %>
              <option <%= isEdit && activity.status === s ? 'selected' : '' %>><%= s %></option>
            <% }); %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label-odoc">Visibility</label>
          <select name="visibility" class="form-select form-select-odoc">
            <option value="public" <%= isEdit && activity.visibility === 'public' ? 'selected' : '' %>>Public</option>
            <option value="draft" <%= isEdit && activity.visibility === 'draft' ? 'selected' : '' %>>Draft</option>
          </select>
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6"><label class="form-label-odoc">Start Date</label><input type="date" name="date" class="form-control form-control-odoc" value="<%= isEdit ? dval(activity.date) : '' %>"></div>
        <div class="col-md-6"><label class="form-label-odoc">End Date</label><input type="date" name="endDate" class="form-control form-control-odoc" value="<%= isEdit ? dval(activity.endDate) : '' %>"></div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6"><label class="form-label-odoc">Location</label><input type="text" name="location" class="form-control form-control-odoc" placeholder="e.g. Main Auditorium" value="<%= isEdit ? activity.location : '' %>"></div>
        <div class="col-md-6"><label class="form-label-odoc">Organizer</label><input type="text" name="organizer" class="form-control form-control-odoc" value="<%= isEdit ? activity.organizer : 'OSIS SMAVO' %>"></div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6"><label class="form-label-odoc">Division</label><input type="text" name="division" class="form-control form-control-odoc" placeholder="e.g. Cultural Affairs" value="<%= isEdit ? activity.division : '' %>"></div>
        <div class="col-md-6"><label class="form-label-odoc">Tags (comma separated)</label><input type="text" name="tags" class="form-control form-control-odoc" placeholder="music, annual, 2024" value="<%= isEdit ? (activity.tags || []).join(', ') : '' %>"></div>
      </div>

      <div class="mb-3">
        <label class="form-label-odoc">Summary</label>
        <input type="text" name="summary" maxlength="200" class="form-control form-control-odoc" placeholder="Short one-line summary shown on cards" value="<%= isEdit ? activity.summary : '' %>">
      </div>

      <div class="mb-3">
        <label class="form-label-odoc">Description</label>
        <textarea name="description" rows="5" class="form-control form-control-odoc" placeholder="Full overview. Separate paragraphs with a blank line."><%= isEdit ? activity.description.join('\n\n') : '' %></textarea>
        <div class="tiny text-muted mt-1">Separate paragraphs with a blank line. Each becomes a paragraph on the public page.</div>
      </div>
    </div>

    <!-- STEP 2: DOCUMENTATION -->
    <div class="wizard-pane">
      <h5 class="fw-bold mb-1">Cover, Gallery &amp; Documents</h5>
      <p class="text-muted small mb-4">Uploads stream to Google Drive. Supported: JPG, PNG, WebP, MP4, PDF, DOCX, XLSX, PPTX, ZIP (max 50MB each).</p>

      <label class="form-label-odoc">Cover Image</label>
      <div class="upload-drop mb-2" data-upload="cover">
        <input type="file" name="cover" accept="image/*" hidden>
        <i class="bi bi-image d-block mb-2"></i>
        <div class="fw-semibold text-dark">Click or drop the cover image</div>
        <div class="tiny">Represents this activity across the archive</div>
      </div>
      <div class="d-flex align-items-center gap-3 mb-4 p-3" id="coverPreviewWrap" style="background:var(--odoc-bg);border-radius:var(--radius-md);display:<%= isEdit && activity.cover ? 'flex' : 'none' %>;">
        <img id="coverPreviewImg" src="<%= isEdit && activity.cover ? activity.cover : '' %>" class="rounded-3" referrerpolicy="no-referrer" onerror="this.closest('#coverPreviewWrap').style.display='none';" style="width:90px;height:70px;object-fit:cover;background:#e3e8f5;">
        <div class="flex-grow-1">
          <div class="fw-semibold text-primary small">Cover Image Preview</div>
          <div class="text-muted tiny">Shown in the gallery, timeline and detail hero.</div>
        </div>
        <button type="button" class="icon-btn text-danger" data-clear-cover title="Remove cover" style="width:34px;height:34px;"><i class="bi bi-x-lg"></i></button>
      </div>

      <label class="form-label-odoc">Gallery (images / video)</label>
      <div class="upload-drop mb-2" data-upload="gallery">
        <input type="file" name="gallery" accept="image/*,video/*" multiple hidden>
        <i class="bi bi-images d-block mb-2"></i>
        <div class="fw-semibold text-dark">Drag &amp; drop images or <span class="text-primary">browse</span></div>
        <div class="tiny">Appears in the public Media Archive</div>
      </div>
      <% if (isEdit && activity.gallery.length) { %>
        <div class="tiny text-muted mb-1">Already saved (<%= activity.gallery.length %>)</div>
        <% activity.gallery.forEach(function(g){ %>
          <div class="file-progress-row"><i class="bi bi-image text-primary"></i><div class="flex-grow-1"><div class="small fw-semibold text-truncate"><%= g %></div></div><span class="tiny text-muted">saved</span></div>
        <% }); %>
      <% } %>
      <div data-chips="gallery" class="mb-4"></div>

      <label class="form-label-odoc">Documents</label>
      <div class="upload-drop mb-2" data-upload="documents">
        <input type="file" name="documents" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.zip" multiple hidden>
        <i class="bi bi-file-earmark-arrow-up d-block mb-2"></i>
        <div class="fw-semibold text-dark">Drag &amp; drop documents or <span class="text-primary">browse</span></div>
        <div class="tiny">PDF, DOCX, XLSX, PPTX, ZIP</div>
      </div>
      <% if (isEdit && activity.documents.length) { %>
        <div class="tiny text-muted mb-1">Already saved (<%= activity.documents.length %>)</div>
        <% activity.documents.forEach(function(d){ %>
          <div class="file-progress-row"><i class="bi bi-file-earmark-text text-danger"></i><div class="flex-grow-1"><div class="small fw-semibold"><%= d.name %></div></div><span class="tiny text-muted"><%= d.size %></span></div>
        <% }); %>
      <% } %>
      <div data-chips="documents"></div>
    </div>

    <!-- STEP 3: COMMITTEE + MILESTONES -->
    <div class="wizard-pane">
      <h5 class="fw-bold mb-1">Core Committee</h5>
      <p class="text-muted small mb-4">People responsible for this activity.</p>

      <div class="row g-3 align-items-end mb-3">
        <div class="col-md-5"><label class="form-label-odoc">Full Name</label><input type="text" id="committeeNameInput" class="form-control form-control-odoc" placeholder="e.g. Sarah Jenkins"></div>
        <div class="col-md-5"><label class="form-label-odoc">Role</label><input type="text" id="committeeRoleInput" class="form-control form-control-odoc" placeholder="e.g. Project Director"></div>
        <div class="col-md-2"><button type="button" id="addCommitteeBtn" class="btn btn-primary w-100 rounded-3"><i class="bi bi-plus-lg me-1"></i>Add</button></div>
      </div>
      <div id="committeeList" class="d-flex flex-column gap-2 mb-2">
        <% if (isEdit) { activity.committee.forEach(function(c){ %>
          <div class="committee-row" data-row>
            <div class="d-flex align-items-center gap-3">
              <span class="member-avatar"><%= (c.name || '?').charAt(0).toUpperCase() %></span>
              <div><div class="fw-semibold small"><%= c.name %></div><div class="text-muted tiny"><%= c.role %></div></div>
            </div>
            <button type="button" class="icon-btn text-danger" data-remove-row title="Remove" style="width:32px;height:32px;"><i class="bi bi-x-lg"></i></button>
            <input type="hidden" name="committeeName" value="<%= c.name %>">
            <input type="hidden" name="committeeRole" value="<%= c.role %>">
          </div>
        <% }); } %>
      </div>
      <div class="tiny text-muted mb-2" id="committeeEmpty" style="display:<%= isEdit && activity.committee.length ? 'none' : 'block' %>;">No committee members added yet.</div>

      <hr class="my-4">

      <h5 class="fw-bold mb-1">Milestones</h5>
      <p class="text-muted small mb-4">Timeline shown on the public page.</p>
      <div class="row g-3 align-items-end mb-3">
        <div class="col-md-6"><label class="form-label-odoc">Milestone Title</label><input type="text" id="milestoneTitleInput" class="form-control form-control-odoc" placeholder="e.g. Event Execution"></div>
        <div class="col-md-4"><label class="form-label-odoc">Date</label><input type="date" id="milestoneDateInput" class="form-control form-control-odoc"></div>
        <div class="col-md-2"><button type="button" id="addMilestoneBtn" class="btn btn-primary w-100 rounded-3"><i class="bi bi-plus-lg me-1"></i>Add</button></div>
      </div>
      <div id="milestoneList" class="d-flex flex-column gap-2 mb-2">
        <% if (isEdit) { activity.milestones.forEach(function(m){ %>
          <div class="committee-row" data-row>
            <div class="d-flex align-items-center gap-3">
              <span class="member-avatar" style="background:#E9EEFC;color:var(--odoc-primary);"><i class="bi bi-flag"></i></span>
              <div><div class="fw-semibold small"><%= m.title %></div><div class="text-muted tiny"><%= m.date %></div></div>
            </div>
            <button type="button" class="icon-btn text-danger" data-remove-row title="Remove" style="width:32px;height:32px;"><i class="bi bi-x-lg"></i></button>
            <input type="hidden" name="milestoneTitle" value="<%= m.title %>">
            <input type="hidden" name="milestoneDate" value="<%= m.date %>">
          </div>
        <% }); } %>
      </div>
      <div class="tiny text-muted" id="milestoneEmpty" style="display:<%= isEdit && activity.milestones.length ? 'none' : 'block' %>;">No milestones added yet.</div>
    </div>

    <!-- STEP 4: REVIEW -->
    <div class="wizard-pane">
      <h5 class="fw-bold mb-1">Review &amp; Publish</h5>
      <p class="text-muted small mb-4">Publish makes it public immediately; Save Draft keeps it hidden from the archive.</p>

      <div class="alert d-flex align-items-center gap-2" style="background:#E9EEFC;border:none;border-radius:var(--radius-md);color:var(--odoc-primary);">
        <i class="bi bi-info-circle"></i> Title is required. Everything else is optional and can be edited later.
      </div>

      <div class="d-flex justify-content-end gap-2">
        <button type="submit" name="action" value="draft" class="btn btn-light rounded-pill px-4">Save Draft</button>
        <button type="submit" name="action" value="publish" class="btn btn-primary rounded-pill px-4"><%= isEdit ? 'Save & Publish' : 'Publish Activity' %> <i class="bi bi-send ms-1"></i></button>
      </div>
    </div>

    <div class="d-flex justify-content-between mt-4 pt-3 border-top">
      <button type="button" class="btn btn-light rounded-pill px-4" data-wizard-prev><i class="bi bi-chevron-left me-1"></i>Back</button>
      <button type="button" class="btn btn-primary rounded-pill px-4" data-wizard-next>Next<i class="bi bi-chevron-right ms-1"></i></button>
    </div>
  </form>
</div>

<style>
  #activityWizard .member-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--odoc-primary); color: #fff; font-weight: 700;
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
    box-shadow: 3px 3px 8px rgba(46,82,228,.3), -3px -3px 8px rgba(255,255,255,.9);
  }
  #activityWizard .committee-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; background: var(--odoc-bg); border-radius: var(--radius-md);
    box-shadow: inset 2px 2px 6px rgba(178,184,192,.45), inset -2px -2px 6px rgba(255,255,255,.7);
  }
  #activityWizard .file-progress-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px; margin-bottom: 8px; background: var(--odoc-bg);
    border-radius: var(--radius-sm);
    box-shadow: inset 1px 1px 4px rgba(178,184,192,.4), inset -1px -1px 4px rgba(255,255,255,.7);
  }
  #activityWizard .upload-drop {
    border: 2px dashed var(--odoc-border); border-radius: var(--radius-md);
    padding: 26px; text-align: center; cursor: pointer; transition: border-color .2s ease;
    background: var(--odoc-bg);
  }
  #activityWizard .upload-drop i { font-size: 1.6rem; color: var(--odoc-primary); }
  #activityWizard .icon-btn {
    border: none; background: var(--odoc-bg); border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    box-shadow: 2px 2px 6px rgba(159,168,182,.42), -2px -2px 6px rgba(247,248,250,.68);
    transition: all .2s ease; flex-shrink: 0;
  }
  #activityWizard .icon-btn:hover { transform: translateY(-1px); }
</style>
