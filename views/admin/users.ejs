<% const isSuperAdmin = currentUser && currentUser.role === 'super_admin'; %>

<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h2 class="fw-bold mb-1">Users</h2>
    <p class="text-muted mb-0">Manage administrator access to the platform.</p>
  </div>
  <% if (isSuperAdmin) { %>
  <button class="btn btn-primary rounded-pill px-4 py-2" data-bs-toggle="modal" data-bs-target="#createUserModal">
    <i class="bi bi-person-plus"></i> Add Admin
  </button>
  <% } %>
</div>

<!-- Users Table -->
<div class="card odoc-panel">
  <div class="table-responsive">
    <table class="table table-odoc table-borderless table-head-divider align-middle mb-0">
      <thead>
        <tr>
          <th>User</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Last Login</th>
          <% if (isSuperAdmin) { %><th class="text-end">Actions</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% if (users && users.length) { %>
          <% users.forEach(function(u) { %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-3">
                <div class="user-avatar" style="--u-avatar: <%= u.avatarColor || '#3155E7' %>;">
                  <%= u.name ? u.name.charAt(0).toUpperCase() : '?' %>
                </div>
                <span class="fw-semibold"><%= u.name %></span>
              </div>
            </td>
            <td class="cell-muted"><%= u.email %></td>
            <td class="cell-muted"><%= u.roleLabel %></td>
            <td>
              <% if (u.active) { %>
                <span class="text-active">Active</span>
              <% } else { %>
                <span class="text-inactive">Inactive</span>
              <% } %>
            </td>
            <td class="cell-muted">
              <% if (u.lastLoginAt) { %>
                <%= new Date(u.lastLoginAt).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) %>
              <% } else { %>
                Never
              <% } %>
            </td>
            <% if (isSuperAdmin) { %>
            <td class="text-end">
              <div class="d-flex gap-2 justify-content-end align-items-center">
                <button class="btn-icon-neu" title="Edit" data-bs-toggle="modal" data-bs-target="#editUserModal"
                  data-id="<%= u.id %>" data-name="<%= u.name %>" data-email="<%= u.email %>" data-role="<%= u.role %>" data-active="<%= u.active %>">
                  <i class="bi bi-pencil"></i>
                </button>
                <% if (u.id !== currentUser.id) { %>
                <form method="POST" action="/admin/users/<%= u.id %>/toggle" class="d-inline">
                  <%- include('../partials/csrf') %>
                  <button class="btn-icon-neu" title="<%= u.active ? 'Deactivate' : 'Activate' %>">
                    <i class="bi bi-<%= u.active ? 'pause-circle' : 'play-circle' %>"></i>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/reset-password" class="d-inline">
                  <%- include('../partials/csrf') %>
                  <button class="btn-icon-neu" title="Reset Password">
                    <i class="bi bi-key"></i>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this user permanently?')">
                  <%- include('../partials/csrf') %>
                  <button class="btn-icon-neu" title="Delete">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
                <% } %>
              </div>
            </td>
            <% } %>
          </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="6" class="text-center py-5 text-muted">No users found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (isSuperAdmin) { %>
<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <form method="POST" action="/admin/users" class="modal-content neu-modal">
      <%- include('../partials/csrf') %>
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <h5 class="modal-title fw-bold">Add New Admin</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4">
        <div class="mb-3">
          <label class="form-label-odoc">Full Name</label>
          <input type="text" name="name" class="form-control form-control-odoc" required>
        </div>
        <div class="mb-3">
          <label class="form-label-odoc">Email</label>
          <input type="email" name="email" class="form-control form-control-odoc" required>
        </div>
        <div class="mb-3">
          <label class="form-label-odoc">Password</label>
          <input type="password" name="password" class="form-control form-control-odoc" required minlength="8">
          <small class="text-muted">User will be forced to change on first login.</small>
        </div>
        <div class="mb-0">
          <label class="form-label-odoc">Role</label>
          <select name="role" class="form-select form-select-odoc">
            <option value="standard_admin">Standard Admin</option>
            <option value="super_admin">Super Admin</option>
          </select>
        </div>
      </div>
      <div class="modal-footer border-0 px-4 pb-4">
        <button type="button" class="btn btn-outline-neu rounded-pill px-3 py-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2">Create User</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <form method="POST" action="#" class="modal-content neu-modal" id="editUserForm">
      <%- include('../partials/csrf') %>
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <h5 class="modal-title fw-bold">Edit User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4">
        <div class="mb-3">
          <label class="form-label-odoc">Full Name</label>
          <input type="text" name="name" class="form-control form-control-odoc" id="editName" required>
        </div>
        <div class="mb-3">
          <label class="form-label-odoc">Email</label>
          <input type="email" class="form-control form-control-odoc email-readonly" id="editEmail" disabled>
        </div>
        <div class="mb-0">
          <label class="form-label-odoc">Role</label>
          <select name="role" class="form-select form-select-odoc" id="editRole">
            <option value="standard_admin">Standard Admin</option>
            <option value="super_admin">Super Admin</option>
          </select>
        </div>
      </div>
      <div class="modal-footer border-0 px-4 pb-4">
        <button type="button" class="btn btn-outline-neu rounded-pill px-3 py-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2">Save Changes</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<script src="/js/users.js"></script>
