<% const isSuperAdmin = currentUser && currentUser.role === 'super_admin'; %>

<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h2 class="fw-bold mb-1">Users</h2>
    <p class="text-muted mb-0">Manage administrator access to the platform.</p>
  </div>
  <% if (isSuperAdmin) { %>
  <button class="btn btn-primary rounded-pill px-4 py-2" data-bs-toggle="modal" data-bs-target="#createUserModal">
    <i class="bi bi-person-plus"></i> Add Admin
  </button>
  <% } %>
</div>

<!-- Users Table -->
<div class="card odoc-panel p-0" style="padding:0 !important;">
  <div class="table-responsive">
    <table class="table table-odoc align-middle mb-0">
      <thead>
        <tr>
          <th class="ps-4">User</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Last Login</th>
          <% if (isSuperAdmin) { %><th class="text-end pe-4">Actions</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% if (users && users.length) { %>
          <% users.forEach(function(u) { %>
          <tr>
            <td class="ps-4">
              <div class="d-flex align-items-center gap-3">
                <div style="width:36px;height:36px;border-radius:50%;background:<%= u.avatarColor || '#3155E7' %>;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:.82rem;flex-shrink:0;">
                  <%= u.name ? u.name.charAt(0).toUpperCase() : '?' %>
                </div>
                <span class="fw-semibold"><%= u.name %></span>
              </div>
            </td>
            <td class="text-muted"><%= u.email %></td>
            <td>
              <span class="text-muted fw-medium" style="font-size:.88rem;"><%= u.roleLabel %></span>
            </td>
            <td>
              <% if (u.active) { %>
                <span style="color:var(--odoc-success);font-weight:600;font-size:.88rem;">Active</span>
              <% } else { %>
                <span style="color:var(--odoc-danger);font-weight:600;font-size:.88rem;">Inactive</span>
              <% } %>
            </td>
            <td>
              <span class="text-muted" style="font-size:.88rem;">
                <% if (u.lastLoginAt) { %>
                  <%= new Date(u.lastLoginAt).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) %>
                <% } else { %>
                  Never
                <% } %>
              </span>
            </td>
            <% if (isSuperAdmin) { %>
            <td class="text-end pe-4">
              <div class="d-flex gap-2 justify-content-end align-items-center">
                <button class="btn btn-secondary" title="Edit" data-bs-toggle="modal" data-bs-target="#editUserModal"
                  data-id="<%= u.id %>" data-name="<%= u.name %>" data-email="<%= u.email %>" data-role="<%= u.role %>" data-active="<%= u.active %>">
                  <i class="bi bi-pencil"></i>
                </button>
                <% if (u.id !== currentUser.id) { %>
                <form method="POST" action="/admin/users/<%= u.id %>/toggle" class="d-inline">
                  <%- include('../partials/csrf') %>
                  <button class="btn btn-secondary" title="<%= u.active ? 'Deactivate' : 'Activate' %>">
                    <i class="bi bi-<%= u.active ? 'pause-circle' : 'play-circle' %>"></i>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/reset-password" class="d-inline">
                  <%- include('../partials/csrf') %>
                  <button class="btn btn-secondary" title="Reset Password">
                    <i class="bi bi-key"></i>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this user permanently?')">
                  <%- include('../partials/csrf') %>
                  <button class="btn btn-secondary" title="Delete">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
                <% } %>
              </div>
            </td>
            <% } %>
          </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="6" class="text-center py-5 text-muted">No users found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (isSuperAdmin) { %>
<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <form method="POST" action="/admin/users" class="modal-content" style="background:var(--odoc-bg);border:none;border-radius:var(--radius-lg);box-shadow:8px 8px 24px rgba(159,168,182,.5),-8px -8px 24px rgba(255,255,255,.92);">
      <%- include('../partials/csrf') %>
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <h5 class="modal-title fw-bold">Add New Admin</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4">
        <div class="mb-3">
          <label class="form-label-odoc">Full Name</label>
          <input type="text" name="name" class="form-control form-control-odoc" required>
        </div>
        <div class="mb-3">
          <label class="form-label-odoc">Email</label>
          <input type="email" name="email" class="form-control form-control-odoc" required>
        </div>
        <div class="mb-3">
          <label class="form-label-odoc">Password</label>
          <input type="password" name="password" class="form-control form-control-odoc" required minlength="8">
          <small class="text-muted">User will be forced to change on first login.</small>
        </div>
        <div class="mb-0">
          <label class="form-label-odoc">Role</label>
          <select name="role" class="form-select form-select-odoc">
            <option value="standard_admin">Standard Admin</option>
            <option value="super_admin">Super Admin</option>
          </select>
        </div>
      </div>
      <div class="modal-footer border-0 px-4 pb-4">
        <button type="button" class="btn btn-outline-neu rounded-pill px-3 py-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2">Create User</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <form method="POST" action="#" class="modal-content" id="editUserForm" style="background:var(--odoc-bg);border:none;border-radius:var(--radius-lg);box-shadow:8px 8px 24px rgba(159,168,182,.5),-8px -8px 24px rgba(255,255,255,.92);">
      <%- include('../partials/csrf') %>
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <h5 class="modal-title fw-bold">Edit User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4">
        <div class="mb-3">
          <label class="form-label-odoc">Full Name</label>
          <input type="text" name="name" class="form-control form-control-odoc" id="editName" required>
        </div>
        <div class="mb-3">
          <label class="form-label-odoc">Email</label>
          <input type="email" class="form-control form-control-odoc" id="editEmail" disabled style="opacity:.5;cursor:not-allowed;">
        </div>
        <div class="mb-0">
          <label class="form-label-odoc">Role</label>
          <select name="role" class="form-select form-select-odoc" id="editRole">
            <option value="standard_admin">Standard Admin</option>
            <option value="super_admin">Super Admin</option>
          </select>
        </div>
      </div>
      <div class="modal-footer border-0 px-4 pb-4">
        <button type="button" class="btn btn-outline-neu rounded-pill px-3 py-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
(function() {
  var editModal = document.getElementById('editUserModal');
  if (editModal) {
    editModal.addEventListener('show.bs.modal', function(event) {
      var btn = event.relatedTarget;
      var form = document.getElementById('editUserForm');
      form.action = '/admin/users/' + btn.getAttribute('data-id') + '/update';
      document.getElementById('editName').value = btn.getAttribute('data-name');
      document.getElementById('editEmail').value = btn.getAttribute('data-email');
      document.getElementById('editRole').value = btn.getAttribute('data-role');
    });
  }
})();
</script>
<% } %>
