<% var alertCount = (typeof systemLogs !== 'undefined' ? systemLogs : []).filter(function(l){ return l.type === 'warning' || l.type === 'error'; }).length; %>
<link rel="stylesheet" href="/css/dashboard.css">

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
  <div>
    <h2 class="fw-bold mb-1">System Overview</h2>
    <p class="text-muted mb-0">Welcome back<%= (typeof currentUser !== 'undefined' && currentUser) ? ', ' + currentUser.name : '' %>. Here's what's happening today.</p>
  </div>
  <a href="/admin/activities/new" class="btn btn-primary rounded-pill px-4"><i class="bi bi-plus-circle me-2"></i>New Activity</a>
</div>

<!-- Live background upload progress (populated by /js/dashboard.js) -->
<div id="uploadProgress" class="odoc-panel card mb-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="panel-title"><i class="bi bi-cloud-arrow-up"></i> Uploading Media</div>
    <span class="badge rounded-pill text-bg-light text-primary fw-semibold" id="uploadProgressCount"></span>
  </div>
  <div id="uploadProgressList" class="d-flex flex-column gap-3"></div>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <a class="stat-card card" href="/admin/activities">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)"><i class="bi bi-journal-richtext"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value"><%= stats.totalActivities.toLocaleString() %></div>
        <div class="stat-label">Total Activities</div>
      </div>
    </a>
  </div>
  <div class="col-6 col-lg-4">
    <a class="stat-card card" href="/admin/storage">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)"><i class="bi bi-cloud"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value"><%= stats.storageUsedGB %> GB</div>
        <div class="stat-label">Storage Used (GDrive)</div>
      </div>
    </a>
  </div>
  <div class="col-6 col-lg-4">
    <a class="stat-card card" href="/admin/users">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)"><i class="bi bi-people"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value"><%= stats.totalUsers %></div>
        <div class="stat-label">Total Users</div>
      </div>
    </a>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-lg-8">
    <div class="odoc-panel card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="panel-title">Recent Activities</div>
        <a href="/admin/activities" class="text-muted small fw-semibold text-decoration-none">View all <i class="bi bi-arrow-right"></i></a>
      </div>
      <div class="table-responsive">
        <table class="table table-odoc mb-0">
          <thead><tr><th>Activity Name</th><th>Category</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody class="table-odoc-row">
            <% if (!recentActivities.length) { %>
              <tr><td colspan="4" class="text-center text-muted py-4">No activities yet. <a href="/admin/activities/new">Create your first one</a>.</td></tr>
            <% } %>
            <% recentActivities.forEach(function(a){ %>
              <tr>
                <td class="fw-semibold"><%= a.title %></td>
                <td><span class="text-muted"><%= a.category %></span></td>
                <td><%= new Date(a.date).toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }) %></td>
                <td class="text-center"><a href="/activity/<%= a.id %>" class="text-muted"><i class="bi bi-box-arrow-up-right"></i></a></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-4 d-flex flex-column gap-4">
    <div class="odoc-panel card">
      <div class="panel-title mb-3">Quick Upload</div>
      <a href="/admin/activities/new" class="upload-drop mb-0 d-block text-decoration-none text-reset">
        <i class="bi bi-cloud-arrow-up d-block mb-2"></i>
        <div class="fw-semibold text-dark">Upload to a new activity</div>
        <div class="tiny">Attach images, video & documents while creating</div>
      </a>
    </div>

    <div class="odoc-panel card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="panel-title">System Logs</div>
        <% if (alertCount) { %><span class="badge rounded-pill text-bg-danger"><%= alertCount %> Alert<%= alertCount === 1 ? '' : 's' %></span><% } else { %><span class="badge rounded-pill text-bg-success">Healthy</span><% } %>
      </div>
      <% if (!systemLogs.length) { %>
        <div class="text-muted small">No recent activity logged yet.</div>
      <% } %>
      <% systemLogs.forEach(function(log){ %>
        <div class="log-item align-items-center">
          <span class="log-icon <%= log.type %>"><i class="bi <%= log.type === 'warning' ? 'bi-exclamation-triangle' : (log.type === 'error' ? 'bi-x-octagon' : (log.type === 'info' ? 'bi-info-circle' : (log.type === 'user' ? 'bi-person-plus' : 'bi-check-circle'))) %>"></i></span>
          <div class="flex-grow-1">
            <div class="fw-semibold small"><%= log.title %></div>
            <div class="text-muted tiny"><%= log.detail %></div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</div>

<script src="/js/dashboard.js"></script>
