<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
  <div>
    <h2 class="fw-bold mb-1">System Overview</h2>
    <p class="text-muted mb-0">Welcome back, Admin. Here's what's happening today.</p>
  </div>
  <button class="btn btn-primary rounded-pill px-4"><i class="bi bi-file-earmark-pdf me-2"></i>Export
    PDF</button>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <a class="stat-card card" href="/admin/activities">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)""><i
            class=" bi bi-journal-richtext"></i>
      </div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value">
          <%= stats.totalActivities.toLocaleString() %>
        </div>
        <div class="stat-label">Total Activities</div>
      </div>
    </a>
  </div>
  <div class="col-6 col-lg-4">
    <a class="stat-card card" href="/admin/storage">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)""><i class=" bi
        bi-cloud"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value">
          <%= stats.storageUsedGB %> GB
        </div>
        <div class="stat-label">Storage Used (GDrive)</div>
      </div>
    </a>
  </div>
  <div class="col-6 col-lg-4">
    <a class="stat-card card" href="/admin/users">
      <div class="stat-icon text-primary" style="background:#E9EEFC;color:var(--odoc-secondary)""><i class=" bi
        bi-people"></i></div>
      <div class="stat-text d-flex flex-column ms-3">
        <div class="stat-value">
          <%= stats.totalUsers %>
        </div>
        <div class="stat-label">Total Users</div>
      </div>
    </a>
  </div>
</div>
<div class="row g-3 mb-4">
  <div class="col-lg-8">
    <div class="odoc-panel card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="panel-title">Recent Activities</div>
        <div class="search-pill" style="min-width:200px;">
          <i class="bi bi-search"></i>
          <input class="form-control border-0 bg-transparent shadow-none" placeholder="Search...">
        </div>
      </div>
      <div class="table-responsive">
        <table class="table table-odoc mb-0">
          <thead>
            <tr>
              <th>Activity Name</th>
              <th>Category</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-odoc-row">
            <% recentActivities.forEach(function(a) { %>
              <tr>
                <td class="fw-semibold">
                  <%= a.title %>
                </td>
                <td><span class="text-muted">
                    <%= a.category %>
                  </span></td>
                <td>
                  <%= new Date(a.date).toLocaleDateString('en-US', { month: 'short' , day: '2-digit' , year: 'numeric'
                    }) %>
                </td>
                <td class="text-center">
                  <i class="view-details text-muted bi bi-box-arrow-up-right"></i>
                </td>
              </tr>
              <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-4 d-flex flex-column gap-4">
    <div class="odoc-panel card">
      <div class="panel-title mb-3">Quick Upload</div>
      <div class="upload-drop mb-3">
        <input type="file" hidden multiple>
        <i class="bi bi-cloud-arrow-up d-block mb-2"></i>
        <div class="fw-semibold text-dark">Drag & drop files</div>
        <div class="tiny">Images, Videos, PDFs (Max 50MB)</div>
      </div>
      <div class="file-progress-row">
        <i class="bi bi-image text-primary"></i>
        <div class="flex-grow-1">
          <div class="small fw-semibold">art_fest_poster.png</div>
        </div>
        <i class="bi bi-check-circle-fill text-success"></i>
      </div>
      <div class="file-progress-row mb-0">
        <i class="bi bi-camera-reels text-primary"></i>
        <div class="flex-grow-1">
          <div class="small fw-semibold">event_aftermovie.mp4</div>
          <div class="progress mt-1">
            <div class="progress-bar" style="width:65%"></div>
          </div>
        </div>
        <i class="bi bi-x text-muted"></i>
      </div>
    </div>

    <div class="odoc-panel card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="panel-title">System Logs</div>
        <span class="badge rounded-pill text-bg-danger">2 Alerts</span>
      </div>
      <% systemLogs.forEach(function(log) { %>
        <div class="log-item align-items-center">
          <span class="log-icon <%= log.type %>">
            <i
              class="bi <%= log.type === 'warning' ? 'bi-exclamation-triangle' : (log.type === 'info' ? 'bi-arrow-down-circle' : 'bi-person-plus') %>"></i>
          </span>
          <div class="flex-grow-1">
            <div class="fw-semibold small">
              <%= log.title %>
            </div>
            <div class="text-muted tiny">
              <%= log.detail %>
            </div>
          </div>
          <i class="details text-muted bi bi-box-arrow-up-right"></i>
        </div>
        <% }); %>
    </div>
  </div>
</div>