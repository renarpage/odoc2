<section class="odoc-login">
  <div class="neu-card login-card">
    <div class="login-brand">
      <span class="login-logo">ODOC</span>
      <p class="login-tagline"><%= (typeof branding !== 'undefined' && branding.tagline) || 'One Door, One Click' %></p>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="neu-alert neu-alert-error"><%= error %></div>
    <% } %>
    <form method="POST" action="/login" id="loginForm" novalidate>
      <div class="neu-field">
        <label for="email">Email</label>
        <input class="neu-input" type="email" id="email" name="email" required autocomplete="username" placeholder="admin@smavo.sch.id">
      </div>
      <div class="neu-field">
        <label for="password">Password</label>
        <input class="neu-input" type="password" id="password" name="password" required autocomplete="current-password" placeholder="********">
      </div>
      <label class="neu-remember"><input type="checkbox" name="remember"> Ingat saya</label>
      <button class="neu-btn neu-btn-primary w-100" type="submit">Masuk</button>
    </form>
    <a class="login-back" href="/">&larr; Kembali ke beranda</a>
  </div>
</section>
